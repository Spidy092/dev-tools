<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Image Resizer' }) %>
</head>
<body>
  <div class="container" id="main-container">
    <%- include('partials/header', { pill: 'SMART ENGINE', h1Left: 'Image', h1Right: 'Resizer', subtitle: 'Bulk resize with smart focus and professional filters.' }) %>

    <div class="mode-tabs">
      <div class="mode-tab active" data-mode="bulk">Bulk Folder</div>
      <div class="mode-tab" data-mode="single">Multiple Files</div>
    </div>

    <div id="options-panel">
      <div class="stats" style="grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div class="stat-card">
          <div class="form-group">
            <label>Dimensions (px)</label>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <input type="number" id="width" placeholder="Width" value="800">
              <input type="number" id="height" placeholder="Height" value="800">
            </div>
          </div>
        </div>
        <div class="stat-card">
          <div class="form-group">
            <label>Fitting Strategy</label>
            <select id="fit">
              <option value="cover">Cover (Focus Subject)</option>
              <option value="contain">Contain (Full Image)</option>
              <option value="fill">Fill (Stretch)</option>
              <option value="inside">Inside (Proportional)</option>
            </select>
          </div>
          <div class="form-group" style="margin-top:15px">
            <label>Rename Pattern</label>
            <input type="text" id="renamePattern" placeholder="e.g. {name}_resized_{index}">
          </div>
        </div>
      </div>
      <div class="stat-card" style="margin-bottom:24px;text-align:left">
        <label style="font-weight:600;margin-bottom:15px;display:block">Advanced Filters</label>
        <div class="feature-grid">
          <label class="feature-opt"><input type="checkbox" id="grayscale"><span>Grayscale</span></label>
          <label class="feature-opt"><input type="checkbox" id="sharpen"><span>Sharpen</span></label>
          <label class="feature-opt"><input type="checkbox" id="negate"><span>Invert Colors</span></label>
          <label class="feature-opt"><input type="checkbox" id="blur-toggle" onclick="document.getElementById('blur').disabled=!this.checked"><span>Blur</span><input type="number" id="blur" value="0.3" step="0.1" min="0" max="10" style="width:60px;margin-left:auto" disabled></label>
        </div>
      </div>
    </div>

    <div id="dropzone" class="dropzone">
      <div class="drop-icon">📐</div>
      <p class="drop-title">Drop your folder here</p>
      <p class="drop-sub">Resized images returned preserving full structure.</p>
      <label class="browse-btn">Browse project<input type="file" id="folder-input" webkitdirectory></label>
    </div>

    <div id="file-tree-panel" class="hidden">
      <div class="form-group"><label>Exclude patterns</label><input type="text" id="exclude-patterns" class="exclude-input" placeholder="e.g. thumbs/*, *.ico"></div>
      <div id="file-tree" class="file-tree-wrap"></div>
      <button id="proceed-btn" class="browse-btn" style="margin-top:12px;width:100%;text-align:center">Process Files</button>
    </div>

    <div id="stats" class="stats hidden">
      <div class="stat-card"><div class="stat-val" id="stat-total">0</div><div class="stat-label">Files queued</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-done">0</div><div class="stat-label">Processed</div></div>
    </div>

    <div id="progress-wrap" class="progress-wrap hidden">
      <div class="progress-label"><span id="progress-text">Scaling pixels...</span><span id="progress-pct">0%</span></div>
      <div class="progress-track"><div id="progress-bar" class="progress-bar" style="width:0%"></div></div>
    </div>

    <div id="log-wrap" class="log-wrap hidden">
      <div class="log-header"><span class="log-dot"></span> Live Processing Log</div>
      <div id="log" class="log"></div>
    </div>

    <div id="download-wrap" class="download-wrap hidden">
      <div class="done-message">Resizing complete!</div>
      <button id="download-btn" class="download-btn">Download Archive (.zip)</button>
      <button id="reset-btn" class="reset-btn">Resize more</button>
    </div>
  </div>

  <script nonce="<%= locals.nonce || '' %>">window.toolEndpoint = '/image-tools/resize';</script>
  <%- include('partials/footer') %>
</body>
</html>
