<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Image Resizer</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="container" id="main-container">
    <a href="/" class="back-link">← Back to Dashboard</a>

    <header>
      <div class="logo-pill">SMART ENGINE</div>
      <h1>Image <span>Resizer</span></h1>
      <p class="subtitle">Bulk resize with smart focus and professional filters.</p>
    </header>

    <!-- Mode Tabs -->
    <div class="mode-tabs">
        <div class="mode-tab active" data-mode="bulk">Bulk Folder</div>
        <div class="mode-tab" data-mode="single">Single File</div>
    </div>

    <!-- Options Section -->
    <div id="options-panel">
        <div class="stats" style="grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div class="stat-card">
                <div class="form-group">
                    <label>Dimensions (px)</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                        <input type="number" id="width" placeholder="Width" value="800">
                        <input type="number" id="height" placeholder="Height" value="800">
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="form-group">
                    <label>Fitting Strategy</label>
                    <select id="fit">
                        <option value="cover">Cover (Focus Subject)</option>
                        <option value="contain">Contain (Full Image)</option>
                        <option value="fill">Fill (Stretch)</option>
                        <option value="inside">Inside (Proportional)</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="stat-card" style="margin-bottom: 24px; text-align: left;">
            <label style="font-weight: 600; margin-bottom: 15px; display: block;">Advanced Filters</label>
            <div class="feature-grid">
                <label class="feature-opt">
                    <input type="checkbox" id="grayscale">
                    <span>Grayscale</span>
                </label>
                <label class="feature-opt">
                    <input type="checkbox" id="sharpen">
                    <span>Sharpen</span>
                </label>
                <label class="feature-opt">
                    <input type="checkbox" id="negate">
                    <span>Invert Colors</span>
                </label>
                <label class="feature-opt">
                    <input type="checkbox" id="blur-toggle" onclick="document.getElementById('blur').disabled = !this.checked">
                    <span>Blur Effect</span>
                    <input type="number" id="blur" value="0.3" step="0.1" min="0" max="10" style="width: 60px; margin-left: auto;" disabled>
                </label>
            </div>
        </div>
    </div>

    <!-- Drop zone -->
    <div id="dropzone" class="dropzone">
      <div class="drop-icon">📐</div>
      <p class="drop-title">Drop your folder here</p>
      <p class="drop-sub">Resized images will be returned preserving full structure.</p>
      <label class="browse-btn">
        Browse project
        <input type="file" id="folder-input" webkitdirectory multiple>
      </label>
    </div>

    <div id="stats" class="stats hidden">
      <div class="stat-card">
        <div class="stat-val" id="stat-total">0</div>
        <div class="stat-label">Files queued</div>
      </div>
      <div class="stat-card">
        <div class="stat-val">READY</div>
        <div class="stat-label">Status</div>
      </div>
    </div>

    <div id="progress-wrap" class="progress-wrap hidden">
      <div class="progress-label">
        <span id="progress-text">Scaling pixels...</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-track">
        <div id="progress-bar" class="progress-bar" style="width: 0%"></div>
      </div>
    </div>

    <div id="download-wrap" class="download-wrap hidden">
      <div class="done-message">Resizing complete!</div>
      <button id="download-btn" class="download-btn">Download Archive (.zip)</button>
      <button id="reset-btn" class="reset-btn">Resize more</button>
    </div>

  </div>

  <script>window.toolEndpoint = '/image-tools/resize';</script>
  <script src="/js/utils.js"></script>
  <script src="/js/tool-runner.js"></script>
</body>
</html>
