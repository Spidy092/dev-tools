<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Code Minifier' }) %>
</head>
<body>
  <div class="container" id="main-container">
    <%- include('partials/header', { pill: 'PERFORMANCE ENGINE', h1Left: 'Code', h1Right: 'Minifier', subtitle: 'Aggressively compress HTML, CSS, and JS recursively.' }) %>

    <div class="mode-tabs">
      <div class="mode-tab active" data-mode="bulk">Bulk Folder</div>
      <div class="mode-tab" data-mode="single">Multiple Files</div>
    </div>

    <div id="options-panel">
      <div class="stats" style="grid-template-columns:1fr;margin-bottom:20px">
        <div class="stat-card" style="text-align:left">
          <label style="font-weight:600;margin-bottom:15px;display:block">Select Targets</label>
          <div class="feature-grid">
            <label class="feature-opt"><input type="checkbox" id="minifyHtml" checked><span>Minify HTML</span></label>
            <label class="feature-opt"><input type="checkbox" id="minifyCss" checked><span>Minify CSS</span></label>
            <label class="feature-opt"><input type="checkbox" id="minifyJs" checked><span>Minify Javascript</span></label>
          </div>
          <p style="font-size:11px;margin-top:10px;color:#6b6b80">Non-selected files will be kept intact in your output zip.</p>
        </div>
      </div>
      <div class="stat-card" style="margin-bottom:24px;text-align:left">
        <label style="font-weight:600;margin-bottom:15px;display:block">Javascript Advanced Settings</label>
        <div class="feature-grid">
          <label class="feature-opt"><input type="checkbox" id="mangleVariables" checked><span>Mangle Variable Names</span></label>
          <label class="feature-opt"><input type="checkbox" id="preserveComments"><span>Preserve Comments</span></label>
          <label class="feature-opt"><input type="checkbox" id="renamePatternToggle" onclick="document.getElementById('renamePattern').disabled=!this.checked"><span>Rename Output</span><input type="text" id="renamePattern" placeholder="{name}.min" style="width:150px;margin-left:auto" disabled></label>
        </div>
      </div>
    </div>

    <div id="dropzone" class="dropzone">
      <div class="drop-icon">⚡</div>
      <p class="drop-title">Drop your codebase here</p>
      <p class="drop-sub">The project will be minified and boxed back into a ZIP.</p>
      <label class="browse-btn">Browse project<input type="file" id="folder-input" webkitdirectory></label>
    </div>

    <div id="file-tree-panel" class="hidden">
      <div class="form-group"><label>Exclude patterns</label><input type="text" id="exclude-patterns" class="exclude-input" placeholder="e.g. node_modules/*, *.min.js"></div>
      <div id="file-tree" class="file-tree-wrap"></div>
      <button id="proceed-btn" class="browse-btn" style="margin-top:12px;width:100%;text-align:center">Process Files</button>
    </div>

    <div id="stats" class="stats hidden">
      <div class="stat-card"><div class="stat-val" id="stat-total">0</div><div class="stat-label">Files queued</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-done">0</div><div class="stat-label">Processed</div></div>
    </div>

    <div id="progress-wrap" class="progress-wrap hidden">
      <div class="progress-label"><span id="progress-text">Minifying code...</span><span id="progress-pct">0%</span></div>
      <div class="progress-track"><div id="progress-bar" class="progress-bar" style="width:0%"></div></div>
    </div>

    <div id="log-wrap" class="log-wrap hidden">
      <div class="log-header"><span class="log-dot"></span> Live Processing Log</div>
      <div id="log" class="log"></div>
    </div>

    <div id="download-wrap" class="download-wrap hidden">
      <div class="done-message">Minification complete!</div>
      <button id="download-btn" class="download-btn">Download Archive (.zip)</button>
      <button id="reset-btn" class="reset-btn">Minify more</button>
    </div>
  </div>

  <script nonce="<%= locals.nonce || '' %>">window.toolEndpoint = '/minify-tools/minify';</script>
  <%- include('partials/footer') %>
</body>
</html>
