<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'PHP Protector' }) %>
</head>
<body>
  <div class="container" id="main-container">
    <%- include('partials/header', { pill: 'SECURE ENGINE', h1Left: 'PHP', h1Right: 'Protector', subtitle: 'Obfuscate PHP code while maintaining directory structure.' }) %>

    <div class="mode-tabs">
      <div class="mode-tab active" data-mode="bulk">Bulk Folder</div>
      <div class="mode-tab" data-mode="single">Multiple Files</div>
    </div>

    <div id="dropzone" class="dropzone">
      <div class="drop-icon">🛡️</div>
      <p class="drop-title">Drop your project folder here</p>
      <p class="drop-sub">PHP files will be obfuscated and returned as ZIP.</p>
      <label class="browse-btn">Browse project<input type="file" id="folder-input" webkitdirectory></label>
    </div>

    <!-- File tree preview (populated by JS after file selection) -->
    <div id="file-tree-panel" class="hidden">
      <div class="form-group">
        <label>Exclude patterns (comma-separated globs)</label>
        <input type="text" id="exclude-patterns" class="exclude-input" placeholder="e.g. vendor/*, node_modules/*, *.log">
      </div>
      <div id="file-tree" class="file-tree-wrap"></div>
      <button id="proceed-btn" class="browse-btn" style="margin-top:12px;width:100%;text-align:center">Process Files</button>
    </div>

    <div id="stats" class="stats hidden">
      <div class="stat-card"><div class="stat-val" id="stat-total">0</div><div class="stat-label">Total files</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-php">0</div><div class="stat-label">PHP files</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-done">0</div><div class="stat-label">Processed</div></div>
    </div>

    <div id="progress-wrap" class="progress-wrap hidden">
      <div class="progress-label"><span id="progress-text">Securing your code...</span><span id="progress-pct">0%</span></div>
      <div class="progress-track"><div id="progress-bar" class="progress-bar" style="width:0%"></div></div>
    </div>

    <div id="log-wrap" class="log-wrap hidden">
      <div class="log-header"><span class="log-dot"></span> Live Processing Log</div>
      <div id="log" class="log"></div>
    </div>

    <div id="download-wrap" class="download-wrap hidden">
      <div class="done-message">Protection complete!</div>
      <button id="download-btn" class="download-btn">Download Archive (.zip)</button>
      <button id="reset-btn" class="reset-btn">Protect more</button>
    </div>
  </div>

  <script nonce="<%= locals.nonce || '' %>">window.toolEndpoint = '/upload';</script>
  <%- include('partials/footer') %>
</body>
</html>
