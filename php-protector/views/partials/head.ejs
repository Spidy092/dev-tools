<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="DevToolkit — fast, private, local developer tools for PHP obfuscation, image processing, PDF compression, file renaming, and code minification.">
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'DevToolkit' %>">
<meta property="og:description" content="Multi-purpose developer tools. Fast, private, and local.">
<meta property="og:type" content="website">
<title><%= typeof title !== 'undefined' ? title : 'DevToolkit' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script nonce="<%= locals.nonce || '' %>">
// Apply saved theme before paint to prevent flash
(function(){var t=localStorage.getItem('devtoolkit_theme');if(t)document.documentElement.setAttribute('data-theme',t)})();
if('serviceWorker' in navigator)navigator.serviceWorker.register('/sw.js').catch(function(){});
</script>
