<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PDF Compressor</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="container" id="main-container">
    <a href="/" class="back-link">← Back to Dashboard</a>

    <header>
      <div class="logo-pill">Ghostscript Engine</div>
      <h1>PDF <span>Compressor</span></h1>
      <p class="subtitle">Shrink PDF file sizes recursively with zero structure loss.</p>
    </header>

    <!-- Mode Tabs -->
    <div class="mode-tabs">
        <div class="mode-tab active" data-mode="bulk">Bulk Folder</div>
        <div class="mode-tab" data-mode="single">Single File</div>
    </div>

    <!-- Options Section -->
    <div id="options-panel" class="stats" style="grid-template-columns: 1fr; margin-bottom: 24px;">
        <div class="stat-card">
            <div class="form-group">
                <label>Compression Level</label>
                <select id="pdfLevel">
                    <option value="/screen" selected>Minimum Size (72 dpi, screen)</option>
                    <option value="/ebook">Medium Quality (150 dpi, ebook)</option>
                    <option value="/printer">Print Quality (300 dpi, print)</option>
                    <option value="/prepress">Max Quality (300 dpi, high-fi)</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Drop zone -->
    <div id="dropzone" class="dropzone">
      <div class="drop-icon">📄</div>
      <p class="drop-title">Drop your PDF folder here</p>
      <p class="drop-sub">PDFs will be optimized and returned in a structured ZIP.</p>
      <label class="browse-btn">
        Browse project
        <input type="file" id="folder-input" webkitdirectory multiple>
      </label>
    </div>

    <div id="stats" class="stats hidden">
      <div class="stat-card">
        <div class="stat-val" id="stat-total">0</div>
        <div class="stat-label">PDFs queued</div>
      </div>
      <div class="stat-card">
        <div class="stat-val">WAITING</div>
        <div class="stat-label">Status</div>
      </div>
    </div>

    <div id="progress-wrap" class="progress-wrap hidden">
      <div class="progress-label">
        <span id="progress-text">Compressing via Ghostscript...</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-track">
        <div id="progress-bar" class="progress-bar" style="width: 0%"></div>
      </div>
    </div>

    <div id="download-wrap" class="download-wrap hidden">
      <div class="done-message">PDFs compressed successfully!</div>
      <button id="download-btn" class="download-btn">Download Archive (.zip)</button>
      <button id="reset-btn" class="reset-btn">Compress more</button>
    </div>

  </div>

  <script>window.toolEndpoint = '/pdf-tools/compress';</script>
  <script src="/js/utils.js"></script>
  <script src="/js/tool-runner.js"></script>
</body>
</html>
